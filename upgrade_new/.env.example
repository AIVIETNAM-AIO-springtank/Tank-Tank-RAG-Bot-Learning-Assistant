# Gemini generation
APP_TITLE=Tank Tank Bot
GEMINI_API_KEY=
GEMINI_API_KEYS=
GEMINI_GENERATION_MODEL=gemini-2.5-flash
GENERATION_PROVIDER=gemini
COHERE_GENERATION_MODEL=command-r7b-12-2024
RAGAS_JUDGE_PROVIDER=gemini
RAGAS_JUDGE_MODEL=gemini-2.5-flash-lite
GEMINI_VISION_MODEL=gemini-2.5-flash

# Cohere embeddings
COHERE_API_KEY=
COHERE_EMBEDDING_MODEL=embed-multilingual-v3.0
COHERE_RERANK_MODEL=rerank-v3.5

# RAG settings
CHROMA_PATH=upgrade_new/chroma_db
COLLECTION_NAME=aio2026_learning_assistant
DEFAULT_TOP_K=4
DEFAULT_RETRIEVAL_MODE=hybrid_rrf
HYBRID_CANDIDATE_K=30
HYBRID_VECTOR_WEIGHT=0.7
HYBRID_KEYWORD_WEIGHT=0.3
RRF_K=60
RERANK_PROVIDER=cohere
RERANK_CANDIDATE_K=30
RERANK_TOP_N=10
FINAL_CONTEXT_K=4
MMR_LAMBDA=0.65
MMR_MIN_TEXT_SIMILARITY=0.82
CHUNK_SIZE=1000
CHUNK_OVERLAP=200
REQUEST_TIMEOUT=60
BATCH_SIZE=32

# Notion integration
NOTION_TOKEN=
NOTION_DATABASE_ID=
ENABLE_NOTION_HASH_WRITE=false
NOTION_CONTENT_HASH_PROPERTY=Content Hash
NOTION_HASH_WRITE_MODE=after_successful_index

# Future feature flags
ENABLE_HYBRID_SEARCH=false
ENABLE_RERANKING=true
ENABLE_MMR=true
ENABLE_OCR=false
VISION_MAX_IMAGES_PER_DOC=20
VISION_IMAGE_DPI=150
ENABLE_CONTENT_HASH_SYNC=false
